{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "gitAuthor": "viserion-renovate[bot] <199991279+viserion-renovate[bot]@users.noreply.github.com>",
  "dependencyDashboardTitle": "Renovate Dashboard 🤖",
  "schedule": ["before 06:00 AM"],
  "rebaseWhen": "conflicted",
  "prHourlyLimit": 0,
  "commitHourlyLimit": 0,

  "extends": [
    "config:recommended",
    ":timezone(Europe/Amsterdam)",    
    ":disableRateLimiting",
    ":semanticCommits",
    ":configMigration",
    "helpers:pinGitHubActionDigests",
    "github>alfi0812/talos//.github/renovate/customManagers.json5",
    "github>alfi0812/talos//.github/renovate/kinds.json5",
    "github>alfi0812/talos//.github/renovate/semanticCommits.json5",
    "github>alfi0812/talos//.github/renovate/labels.json5",
    "github>alfi0812/talos//.github/renovate/autoMerge.json5",
    "github>alfi0812/talos//.github/renovate/groups.json5",
    "github>alfi0812/talos//.github/renovate/special_grafanadashboard.json5"
  ],

  "ignorePaths": [
    "**/*.sops.*",
    "**/.archive/**",
    "**/archive/**",
    "**/resources/**"
  ]
}